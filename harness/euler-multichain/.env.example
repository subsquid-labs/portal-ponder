# Copy to .env and fill in. NONE of these are committed.
#
# SQD Portal API key (backfill data source). Used for every chain's `portal:` dataset.
PORTAL_API_KEY=

# SQD RPC key (realtime + finality tail, and chain-id validation at startup). The config builds
# https://rpc.subsquid.io/<slug>/$SQD_RPC_KEY for the 10 chains SQD serves; the other 5 fall back to
# the keyless public RPCs already in chains.json. Leave blank to run entirely on public RPCs.
SQD_RPC_KEY=

# Production DB (from docker-compose). Unset → falls back to in-process pglite (dev only; a fast
# 15-chain backfill can OOM pglite because its writer shares the Node heap — use Postgres for the full run).
DATABASE_URL=postgres://postgres@localhost:5433/euler

# Optional: limit the run to a subset, e.g. EULER_CHAINS=ethereum,base,arbitrum
# EULER_CHAINS=
