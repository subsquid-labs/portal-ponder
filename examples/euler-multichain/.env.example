# Every value here is OPTIONAL — `npm run dev` works with no .env at all (keyless defaults).
# Portal datasets per chain are set in ponder.config.ts (free public Portal, no key needed).

# Realtime tip + state reads per chain. Default to keyless *archive* public RPCs (drpc.org) —
# archive is required because reads happen at historical blocks. They rate-limit under load, so
# set your own per chain for a longer backfill or production:
# PONDER_RPC_URL_1=https://eth.your-archive-rpc.example
# PONDER_RPC_URL_8453=https://base.your-archive-rpc.example
# PONDER_RPC_URL_42161=https://arb.your-archive-rpc.example

# Demo window. Each chain defaults to ~200k blocks from its factory deploy. Override:
# PONDER_DEMO_SPAN=200000   # blocks per chain from each factory startBlock
# PONDER_FULL=1             # backfill full history on every chain instead

# PORTAL_API_KEY=   # only if using a dedicated/keyed portal
