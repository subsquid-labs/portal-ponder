# Every value here is OPTIONAL — `npm run dev` works with no .env at all (keyless defaults).

# Historical backfill from SQD Portal. Defaults to the free public Portal (no key needed):
# PORTAL_URL=https://portal.sqd.dev/datasets/ethereum-mainnet
# PORTAL_API_KEY=

# Realtime tip + state reads. Defaults to a keyless *archive* public RPC (eth.drpc.org), which
# rate-limits under load — set your own for a longer backfill or production:
# PONDER_RPC_URL_1=https://eth.your-archive-rpc.example

# Demo window (defaults to a 10k-block span, 22200000 → 22210000). Override:
# PONDER_START=22200000
# PONDER_END=22210000
